<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">
    <!-- entire symbol is a tilted $ variant: rotate 12 degrees CW as a group -->
    <group
        android:rotation="12"
        android:pivotX="12"
        android:pivotY="12">
        <!-- top stub (vertical center line, above bars) -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M10.5,2.5 h3 v4 h-3 Z"/>
        <!-- top bar -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M5,7.5 h14 v2.5 h-14 Z"/>
        <!-- middle bar -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M5,11 h14 v2.5 h-14 Z"/>
        <!-- bottom bar -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M5,14.5 h14 v2.5 h-14 Z"/>
        <!-- bottom stub (vertical center line, below bars) -->
        <path
            android:fillColor="#FF000000"
            android:pathData="M10.5,18.5 h3 v3 h-3 Z"/>
    </group>
</vector>
